{
  "name": "@kd/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:load": "artillery run tests/load/artillery.yml",
    "db:migrate": "tsx --env-file=.env db/scripts/migrate.ts",
    "db:migrate:dry": "tsx --env-file=.env db/scripts/migrate.ts --dry-run",
    "db:seed": "tsx --env-file=.env db/scripts/seed.ts",
    "db:indexes": "tsx --env-file=.env db/scripts/create-mongo-indexes.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@kd/shared": "*",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.0.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.4.0",
    "mongodb": "^6.8.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "artillery": "^2.0.30",
    "vitest": "^4.1.0"
  }
}
