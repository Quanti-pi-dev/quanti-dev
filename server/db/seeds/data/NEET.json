":"Isotopes differ in neutron number.","tags":["chemistry","isotopes","concept"]},{"question":"Bohr model explains?","options":[{"id":"A","text":"Energy levels"},{"id":"B","text":"Molecules"},{"id":"C","text":"Compounds"},{"id":"D","text":"Reactions"}],"correctAnswerId":"A","explanation":"Bohr explained quantized energy levels.","tags":["chemistry","bohr","theory"]}],"Expert":[{"question":"Quantum number n represents?","options":[{"id":"A","text":"Principal level"},{"id":"B","text":"Spin"},{"id":"C","text":"Shape"},{"id":"D","text":"Orientation"}],"correctAnswerId":"A","explanation":"n is principal quantum number.","tags":["chemistry","quantum","advanced"]},{"question":"Orbital shape determined by?","options":[{"id":"A","text":"l"},{"id":"B","text":"n"},{"id":"C","text":"m"},{"id":"D","text":"s"}],"correctAnswerId":"A","explanation":"Azimuthal quantum number determines shape.","tags":["chemistry","orbitals","advanced"]}],"Master":[{"question":"Heisenberg principle states?","options":[{"id":"A","text":"Uncertainty"},{"id":"B","text":"Certainty"},{"id":"C","text":"Energy conservation"},{"id":"D","text":"Momentum conservation"}],"correctAnswerId":"A","explanation":"Position and momentum cannot be simultaneously known.","tags":["chemistry","quantum","master"]},{"question":"de Broglie equation relates?","options":[{"id":"A","text":"Wavelength and momentum"},{"id":"B","text":"Mass and charge"},{"id":"C","text":"Energy and time"},{"id":"D","text":"Velocity and force"}],"correctAnswerId":"A","explanation":"λ=h/p relates wavelength and momentum.","tags":["chemistry","wave","advanced"]}]}}]},{"name":"Biology","description":"Study of living organisms.","iconName":"leaf-outline","accent":"#22C55E","topics":[{"slug":"cell-biology","displayName":"Cell Biology","levels":{"Beginner":[{"question":"Basic unit of life?","options":[{"id":"A","text":"Cell"},{"id":"B","text":"Atom"},{"id":"C","text":"Molecule"},{"id":"D","text":"Organ"}],"correctAnswerId":"A","explanation":"Cell is the basic unit of life.","tags":["biology","cell","basics"]},{"question":"Cell membrane function?","options":[{"id":"A","text":"Controls entry/exit"},{"id":"B","text":"Stores DNA"},{"id":"C","text":"Produces energy"},{"id":"D","text":"Synthesizes proteins"}],"correctAnswerId":"A","explanation":"Membrane regulates transport.","tags":["biology","cell","function"]}],"Rookie":[{"question":"Nucleus contains?","options":[{"id":"A","text":"DNA"},{"id":"B","text":"RNA"},{"id":"C","text":"Protein"},{"id":"D","text":"Lipids"}],"correctAnswerId":"A","explanation":"DNA is housed in nucleus.","tags":["biology","cell","genetics"]},{"question":"Mitochondria function?","options":[{"id":"A","text":"Energy production"},{"id":"B","text":"Digestion"},{"id":"C","text":"Transport"},{"id":"D","text":"Storage"}],"correctAnswerId":"A","explanation":"Mitochondria produce ATP.","tags":["biology","organelles","energy"]}],"Skilled":[{"question":"Ribosomes synthesize?","options":[{"id":"A","text":"Proteins"},{"id":"B","text":"Lipids"},{"id":"C","text":"DNA"},{"id":"D","text":"Carbohydrates"}],"correctAnswerId":"A","explanation":"Ribosomes synthesize proteins.","tags":["biology","protein","cell"]},{"question":"Golgi apparatus role?","options":[{"id":"A","text":"Packaging"},{"id":"B","text":"Energy"},{"id":"C","text":"DNA replication"},{"id":"D","text":"Respiration"}],"correctAnswerId":"A","explanation":"Golgi packages proteins.","tags":["biology","organelles","function"]}],"Competent":[{"question":"Cell wall found in?","options":[{"id":"A","text":"Plants"},{"id":"B","text":"Animals"},{"id":"C","text":"Humans"},{"id":"D","text":"Bacteria only"}],"correctAnswerId":"A","explanation":"Plants have cell wall.","tags":["biology","plants","structure"]},{"question":"Lysosomes contain?","options":[{"id":"A","text":"Digestive enzymes"},{"id":"B","text":"DNA"},{"id":"C","text":"RNA"},{"id":"D","text":"ATP"}],"correctAnswerId":"A","explanation":"Lysosomes digest waste.","tags":["biology","organelles","digest"]}],"