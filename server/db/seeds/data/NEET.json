{"exams":[{"title":"NEET","description":"National Entrance Test for admission to medical courses in India.","category":"Medical","durationMinutes":200,"subjects":[{"name":"Physics","description":"Study of matter, energy, and their interactions.","iconName":"speedometer-outline","accent":"#3B82F6","topics":[{"slug":"kinematics","displayName":"Kinematics","levels":{"Beginner":[{"question":"What is the SI unit of velocity?","options":[{"id":"A","text":"m/s"},{"id":"B","text":"km/h"},{"id":"C","text":"cm/s"},{"id":"D","text":"m/s²"}],"correctAnswerId":"A","explanation":"Velocity is distance per unit time, and its SI unit is meters per second.","tags":["physics","kinematics","units"]},{"question":"What does a speedometer measure?","options":[{"id":"A","text":"Velocity"},{"id":"B","text":"Acceleration"},{"id":"C","text":"Speed"},{"id":"D","text":"Displacement"}],"correctAnswerId":"C","explanation":"A speedometer measures the magnitude of velocity, i.e., speed.","tags":["physics","kinematics","basics"]}],"Rookie":[{"question":"What is acceleration?","options":[{"id":"A","text":"Rate of change of velocity"},{"id":"B","text":"Distance covered"},{"id":"C","text":"Time taken"},{"id":"D","text":"Force applied"}],"correctAnswerId":"A","explanation":"Acceleration is defined as the rate of change of velocity with respect to time.","tags":["physics","kinematics","acceleration"]},{"question":"If velocity is constant, acceleration is?","options":[{"id":"A","text":"Zero"},{"id":"B","text":"Infinite"},{"id":"C","text":"Negative"},{"id":"D","text":"Positive"}],"correctAnswerId":"A","explanation":"If velocity does not change, acceleration is zero.","tags":["physics","motion","concept"]}],"Skilled":[{"question":"A body starts from rest. What is its initial velocity?","options":[{"id":"A","text":"Zero"},{"id":"B","text":"1 m/s"},{"id":"C","text":"Depends on time"},{"id":"D","text":"Infinite"}],"correctAnswerId":"A","explanation":"Starting from rest means initial velocity is zero.","tags":["physics","kinematics","motion"]},{"question":"Which graph represents uniform motion?","options":[{"id":"A","text":"Straight line in distance-time graph"},{"id":"B","text":"Curve in distance-time graph"},{"id":"C","text":"Zigzag graph"},{"id":"D","text":"Random points"}],"correctAnswerId":"A","explanation":"Uniform motion has constant velocity, giving a straight line in distance-time graph.","tags":["physics","graphs","motion"]}],"Competent":[{"question":"Slope of velocity-time graph gives?","options":[{"id":"A","text":"Acceleration"},{"id":"B","text":"Velocity"},{"id":"C","text":"Distance"},{"id":"D","text":"Time"}],"correctAnswerId":"A","explanation":"Slope of velocity-time graph represents acceleration.","tags":["physics","graphs","advanced"]},{"question":"Area under velocity-time graph gives?","options":[{"id":"A","text":"Displacement"},{"id":"B","text":"Acceleration"},{"id":"C","text":"Velocity"},{"id":"D","text":"Force"}],"correctAnswerId":"A","explanation":"Area under velocity-time graph gives displacement.","tags":["physics","graphs","concept"]}],"Expert":[{"question":"Equation of motion: v = u + at represents?","options":[{"id":"A","text":"Final velocity"},{"id":"B","text":"Distance"},{"id":"C","text":"Time"},{"id":"D","text":"Acceleration"}],"correctAnswerId":"A","explanation":"This equation calculates final velocity after time t.","tags":["physics","equations","motion"]},{"question":"If u=0, v=10 m/s, a=2 m/s², find t.","options":[{"id":"A","text":"5 s"},{"id":"B","text":"2 s"},{"id":"C","text":"10 s"},{"id":"D","text":"8 s"}],"correctAnswerId":"A","explanation":"Using v=u+at → 10=0+2t → t=5s.","tags":["physics","numerical","kinematics"]}],"Master":[{"question":"A particle moves with constant acceleration. Which is true?","options":[{"id":"A","text":"Velocity changes linearly"},{"id":"B","text":"Velocity is constant"},{"id":"C","text":"Acceleration is zero"},{"id":"D","text":"Displacement is constant"}],"correctAnswerId":"A","explanation":"Constant acceleration leads to linear change in velocity.","tags":["physics","conceptual","advanced"]},{"question":"Which equation is dimensionally correct?","options":[{"id":"A","text":"v² = u² + 2as"},{"id":"B","text":"v = u + s"},{"id":"C","text":"a = v + t"},{"id":"D","text":"s = ut²"}],"correctAnswerId":"A","explanation":"v² = u² + 2as is dimensionally correct equation of motion.","tags":["physics","dimensions","master"]}]}},{"slug":"laws-of-motion","displayName":"Laws of Motion","levels":{"Beginner":[{"question":"Who proposed laws of motion?","options":[{"id":"A","text":"Newton"},{"id":"B","text":"Einstein"},{"id":"C","text":"Galileo"},{"id":"D","text":"Bohr"}],"correctAnswerId":"A","explanation":"Newton proposed the three laws of motion.","tags":["physics","laws","history"]},{"question":"First law is also called?","options":[{"id":"A","text":"Law of inertia"},{"id":"B","text":"Law of force"},{"id":"C","text":"Law of energy"},{"id":"D","text":"Law of gravity"}],"correctAnswerId":"A","explanation":"Newton’s first law is known as the law of inertia.","tags":["physics","laws","basics"]}],"Rookie":[{"question":"Force = ?","options":[{"id":"A","text":"ma"},{"id":"B","text":"mv"},{"id":"C","text":"m/a"},{"id":"D","text":"v/a"}],"correctAnswerId":"A","explanation":"Newton’s second law states F = ma.","tags":["physics","force","formula"]},{"question":"Unit of force is?","options":[{"id":"A","text":"Newton"},{"id":"B","text":"Joule"},{"id":"C","text":"Watt"},{"id":"D","text":"Pascal"}],"correctAnswerId":"A","explanation":"SI unit of force is Newton.","tags":["physics","units","force"]}],"Skilled":[{"question":"Momentum = ?","options":[{"id":"A","text":"mv"},{"id":"B","text":"ma"},{"id":"C","text":"v/t"},{"id":"D","text":"m/t"}],"correctAnswerId":"A","explanation":"Momentum is product of mass and velocity.","tags":["physics","momentum","formula"]},{"question":"Impulse equals?","options":[{"id":"A","text":"Change in momentum"},{"id":"B","text":"Force"},{"id":"C","text":"Mass"},{"id":"D","text":"Velocity"}],"correctAnswerId":"A","explanation":"Impulse is change in momentum.","tags":["physics","impulse","concept"]}],"Competent":[{"question":"Action-reaction forces act on?","options":[{"id":"A","text":"Different bodies"},{"id":"B","text":"Same body"},{"id":"C","text":"No body"},{"id":"D","text":"Only moving body"}],"correctAnswerId":"A","explanation":"They act on different bodies.","tags":["physics","laws","third-law"]},{"question":"Friction depends on?","options":[{"id":"A","text":"Nature of surfaces"},{"id":"B","text":"Time"},{"id":"C","text":"Volume"},{"id":"D","text":"Temperature"}],"correctAnswerId":"A","explanation":"Friction depends on nature of surfaces.","tags":["physics","friction","concept"]}],"Expert":[{"question":"Coefficient of friction is?","options":[{"id":"A","text":"Ratio"},{"id":"B","text":"Product"},{"id":"C","text":"Sum"},{"id":"D","text":"Difference"}],"correctAnswerId":"A","explanation":"It is ratio of frictional force to normal force.","tags":["physics","friction","advanced"]},{"question":"Unit of momentum?","options":[{"id":"A","text":"kg m/s"},{"id":"B","text":"N"},{"id":"C","text":"J"},{"id":"D","text":"W"}],"correctAnswerId":"A","explanation":"Momentum has unit kg m/s.","tags":["physics","units","momentum"]}],"Master":[{"question":"Rocket propulsion works on?","options":[{"id":"A","text":"Third law"},{"id":"B","text":"First law"},{"id":"C","text":"Second law"},{"id":"D","text":"Gravity"}],"correctAnswerId":"A","explanation":"Rocket propulsion is based on action-reaction.","tags":["physics","applications","laws"]},{"question":"Net force zero implies?","options":[{"id":"A","text":"No acceleration"},{"id":"B","text":"High velocity"},{"id":"C","text":"Infinite force"},{"id":"D","text":"Random motion"}],"correctAnswerId":"A","explanation":"Zero net force implies no acceleration.","tags":["physics","equilibrium","concept"]}]}}]},{"name":"Chemistry","description":"Study of substances and reactions.","iconName":"flask-outline","a